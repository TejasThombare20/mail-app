# Backend API base URL
VITE_API_BASE_URL=http://localhost:3000

# Supabase (used for media/attachment storage)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_key
VITE_SUPABASE_BUCKET_NAME=bucket-name

# ----------------------------------------------------------------
# Firebase — currently NOT used.
# Google OAuth is handled server-side via /api/auth/google/url.
# Uncomment and fill these in if you re-enable Firebase auth.
# ----------------------------------------------------------------
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
# VITE_MEASUREMENT_ID=G-XXXXXXXXXX
