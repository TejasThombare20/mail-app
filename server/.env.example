# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
AUTH_REDIRECT_ENDPOINT=/auth/callback

# JWT
JWT_SECRET=your_jwt_secret

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Supabase (media storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Default attachment (fallback PDF when template has no attachments)
DEFAULT_ATTACHMENT_ENABLED=true
DEFAULT_ATTACHMENT_DIR=public
DEFAULT_ATTACHMENT_FILE_NAME=Tejas Thombare IIIT Gwalior.pdf
